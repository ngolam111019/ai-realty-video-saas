{
  "name": "services-video-processor",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:vision": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-vision.ts",
    "test:video-vision": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-video-vision.ts",
    "test:cache": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-cache.ts",
    "test:script-gen": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-script-gen.ts",
    "test:draft-saver": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-draft-saver.ts",
    "test:orchestrator": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-orchestrator.ts",
    "test:pipeline": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-full-pipeline-interactive.ts",
    "test:render-pipeline": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-full-render-interactive.ts",
    "test:e2e": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-e2e-connected.ts",
    "test:pipeline-clean": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/clean-interactive-test.ts",
    "test:tts-fpt": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-tts-fpt.ts",
    "test:tts-cache": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-tts-cache.ts",
    "test:clip-extractor": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-clip-extractor.ts",
    "test:timeline-builder": "ts-node --compiler-options '{\"module\": \"commonjs\", \"moduleResolution\": \"node\"}' scripts/test-timeline-builder.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.554.0",
    "@google/generative-ai": "^0.11.0",
    "@realty-video/database": "workspace:*",
    "axios": "^1.17.0",
    "bullmq": "^5.8.2",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "mime-types": "^2.1.35",
    "p-limit": "^3.1.0",
    "pino": "^8.19.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.11.24",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "pino-pretty": "^10.3.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2"
  }
}
